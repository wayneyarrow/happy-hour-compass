# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored — never commit real keys.

# ─── Supabase ─────────────────────────────────────────────────────────────────

# Project URL (Supabase Dashboard → Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable key (Settings → API → API Keys → publishable — starts with sb_publishable_)
# Safe for browser and server use.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Secret key (Settings → API → API Keys — starts with sb_secret_)
# SERVER-SIDE ONLY — never prefix with NEXT_PUBLIC_ or expose to the browser.
SUPABASE_SECRET_KEY=sb_secret_...

# ─── Stripe — Billing & Payments ──────────────────────────────────────────────
# Use test keys (sk_test_ / pk_test_) for development and beta.
# Switch to live keys (sk_live_ / pk_live_) only when billing goes live in production.

# Secret key (Stripe Dashboard → Developers → API Keys → Secret key)
# SERVER-SIDE ONLY.
STRIPE_SECRET_KEY=sk_test_...

# Publishable key (Stripe Dashboard → Developers → API Keys → Publishable key)
# Safe for browser use.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Price IDs for the monthly recurring plans
# (Stripe Dashboard → Product catalogue → [plan] → Pricing → copy the price ID)
STRIPE_PRO_PRICE_ID=price_...
STRIPE_PREMIUM_PRICE_ID=price_...

# Webhook signing secret — source depends on environment:
#
#   Local dev:   Run `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
#                The CLI prints a signing secret (whsec_...) — copy it here.
#                Restart the dev server after updating this value.
#
#   Vercel / production: Stripe Dashboard → Developers → Webhooks → [your endpoint]
#                        → Signing secret → Reveal → copy the whsec_ value.
#
# ⚠ The CLI secret and Dashboard secret are DIFFERENT values — do not mix them.
#   The CLI secret is temporary and changes each `stripe listen` session.
#   The Dashboard secret is permanent for the registered endpoint.
STRIPE_WEBHOOK_SECRET=whsec_...

# Canonical app URL — used to build Stripe success_url and cancel_url.
# Required in Vercel so Stripe redirects back to the right domain after checkout.
# Without this, the app falls back to VERCEL_URL (deployment-specific), which
# changes on each deploy and can cause 404s on redirect.
# Example: https://admin.happyhourcompass.com or https://operator-admin.vercel.app
APP_URL=https://...

# ─── Email (Resend) ───────────────────────────────────────────────────────────

# Resend API key (resend.com → API Keys)
# Used for transactional emails: claim approvals, operator invites, etc.
RESEND_API_KEY=re_...

# Email address to notify on new operator submissions and venue claims.
# Use a real inbox you monitor — this is where ops notification emails land.
FOUNDER_NOTIFICATION_EMAIL=you@example.com

# ─── Google APIs ──────────────────────────────────────────────────────────────

# Google Maps JavaScript SDK — safe for browser use.
# Enable "Maps JavaScript API" for this key in Google Cloud Console.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...

# Google Places API (New) — SERVER-SIDE ONLY. Never prefix with NEXT_PUBLIC_.
# Used by the operator submission flow (/suggest/owner) to look up venues.
# Enable "Places API (New)" for this key in Google Cloud Console.
GOOGLE_PLACES_API_KEY=AIza...

# ─── Slack (Ops Alerts) ───────────────────────────────────────────────────────
# Used to send internal ops notifications (payment failures, critical errors).
# Create incoming webhooks at api.slack.com → your app → Incoming Webhooks.
# Optional: alerts are silently skipped if these are not set.

SLACK_OPS_CRITICAL_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_OPS_ALERTS_WEBHOOK_URL=https://hooks.slack.com/services/...

# ─── Admin & Control Panel ────────────────────────────────────────────────────

# Comma-separated list of email addresses allowed to access /control-panel/*.
# These are internal platform admin accounts — not operator accounts.
# Example: admin@example.com,ops@example.com
CONTROL_PANEL_ADMIN_EMAILS=

# ─── Sentry — Application Error Monitoring ────────────────────────────────────
# https://sentry.io → happy-hour-compass org → javascript-nextjs project

# DSN (Data Source Name) — safe to expose publicly; write-only for event ingestion.
# Found at: Sentry → Settings → Projects → javascript-nextjs → Client Keys (DSN)
# Must be prefixed NEXT_PUBLIC_ because it is used by the client-side SDK.
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxx@oxxxxxx.ingest.sentry.io/xxxxxxx

# Environment tag attached to every Sentry event.
# Omit for local dev — sentry.client.config.ts defaults to NODE_ENV.
# Set to "production" in Vercel production environment settings.
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=production

# ── Source map upload (optional on Vercel Hobby) ──────────────────────────────
# Without these, Sentry still captures errors — stack traces will show
# minified code. Add them when you're ready to see human-readable traces.
#
# Auth token: Sentry → Settings → Auth Tokens → Create new token
#   (needs project:releases and org:read scopes)
# SENTRY_AUTH_TOKEN=sntrys_...
#
# Organization slug: Sentry → Settings → General → Organization Slug
# SENTRY_ORG=happy-hour-compass
#
# Project slug: Sentry → Settings → Projects → javascript-nextjs → General → Name
# SENTRY_PROJECT=javascript-nextjs

# ── Sentry test route (temporary — remove after verification) ─────────────────
# Set to "true" in Vercel to enable /api/sentry-example-api for one deploy.
# After confirming the test error appears in Sentry, remove this var and delete
# the file src/app/api/sentry-example-api/route.ts.
# SENTRY_TEST_ROUTE_ENABLED=true
