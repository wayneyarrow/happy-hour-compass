# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored — never commit real keys.

# Supabase project URL (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase publishable key (new-style key starting with sb_publishable_...)
# Safe for browser/client-side use.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Supabase secret key (new-style key starting with sb_secret_...)
# SERVER-SIDE ONLY — never expose this to the browser or commit it to git.
SUPABASE_SECRET_KEY=sb_secret_...

# Google Maps JavaScript SDK (consumer map view — safe for client/browser)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Google Places API (New) — server-side only, NEVER prefix with NEXT_PUBLIC_
# Used by the operator submission flow (/suggest/owner) to look up venues.
# Required in Vercel: Settings → Environment Variables → add for Production,
# Preview, and Development. Enable "Places API (New)" in Google Cloud Console
# for the key you use here.
GOOGLE_PLACES_API_KEY=
